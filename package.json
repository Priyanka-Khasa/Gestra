{
  "name": "gestureos",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "electron:dev": "vite",
    "start": "vite",
    "build": "vite build",
    "postbuild": "copy /Y electron\\main.cjs dist-electron\\main.cjs && copy /Y electron\\preload.cjs dist-electron\\preload.cjs",
    "preview": "vite preview",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "@mediapipe/drawing_utils": "^0.3.1675466124",
    "@mediapipe/hands": "^0.4.1675466139",
    "@mediapipe/tasks-vision": "^0.10.22",
    "@nut-tree-fork/nut-js": "^4.2.6",
    "html2canvas": "^1.4.1"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.19",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "build": {
    "appId": "com.gestureos.desktop",
    "productName": "GestureOS",
    "files": [
      "dist/**",
      "dist-electron/**",
      "electron/**",
      "package.json"
    ],
    "directories": {
      "buildResources": "public"
    },
    "win": {
      "target": "nsis"
    }
  }
}
