# Copy to `.env` and fill in. Vite exposes only vars prefixed with VITE_.

# xAI Grok takes priority if set
# VITE_XAI_API_KEY=
# VITE_XAI_MODEL=grok-3-latest
# VITE_XAI_BASE_URL=https://api.x.ai/v1

# OpenRouter is used only if xAI is not set
VITE_OPENROUTER_API_KEY=
# Optional overrides:
# VITE_OPENROUTER_MODEL=openrouter/auto
# VITE_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Google Gemini is the fallback provider if neither xAI nor OpenRouter is set
VITE_GEMINI_API_KEY=
# Optional overrides:
# VITE_GEMINI_MODEL=gemini-2.0-flash
# VITE_GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
